[
    {% for post in site.posts %}
    {
        "title": {{ post.title | escape | strip | jsonify }},
        "content": {{ post.content | strip_html | escape | truncate: 500 | strip | jsonify }},
        "tags": {{ post.tags | jsonify }},
        "url": {{ post.url | relative_url | jsonify }},
        "date": {{ post.date | date: '%Y/%m/%d' | jsonify }},
        "lang": {{ post.lang | default: 'zh' | strip | jsonify }}
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
]