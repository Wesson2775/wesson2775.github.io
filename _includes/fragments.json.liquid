[
    {% for fragment in site.fragments %}
    {
        "title": {{ fragment.title | jsonify }},
        "content": {{ fragment.content | strip_html | escape | truncate: 500 | strip | jsonify }},
        "date": "{{ fragment.date | date: "%Y/%m/%d" }}",
        "url": "{{ fragment.url | relative_url }}",
        "lang": {{ fragment.lang | default: 'zh' | strip | jsonify }},
        "category": {{ fragment.category | default: 'fragments' | strip | jsonify }},
        "tags": {{ fragment.tags | jsonify }}
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
]